#!/usr/bin/env bash

set -uo pipefail

ROOT_DIR=""

usage() {
  cat >&2 <<'EOF'
Usage:
  sbxctl [--root PATH] create {name}
  sbxctl [--root PATH] start {name}
  sbxctl [--root PATH] shell {name} [command...]
  sbxctl [--root PATH] stop {name}
  sbxctl [--root PATH] reset {name}
  sbxctl [--root PATH] snapshot {name} [output_path]
  sbxctl [--root PATH] restore {name} {snapshot_path}
  sbxctl [--root PATH] delete {name}
  sbxctl [--root PATH] status [name]

Commands:
  create    Bootstrap a new sandbox and save its clean base image
  start     Boot a sandbox with configured mounts, ports, and optional audio
  shell     Open a shell or run a command as SANDBOX_USER inside a running sandbox
  stop      Power off a running sandbox
  reset     Restore a sandbox from its clean base image
  snapshot  Save a stopped sandbox rootfs to a tar.zst archive
  restore   Replace a sandbox rootfs from a snapshot archive
  delete    Remove a sandbox, its base tarball, and per-sandbox config files
  status    Show global health check or status of a specific sandbox

Configuration:
  Root directory defaults to \$PWD and may be overridden by:
    1. --root PATH
    2. OPQU_SBX_ROOT=/path/to/root

  Optional files under ROOT/conf/:
    global.conf       Global defaults such as DISTRO, MIRROR, VARIANT, SANDBOX_USER
    {name}.conf       Sandbox runtime settings such as PORTS and AUDIO (default: no)
    {name}.packages   Extra packages to install during create, one per line
    {name}.mounts     Bind mounts in host_path:container_path[:ro] format

Notes:
  Sandbox names must be 1-12 characters of [a-z0-9-].
  'create' requires a root path without whitespace.
  Most commands use sudo because the container runs without user namespaces.
EOF
}

error() {
  printf '%s\n' "$*" >&2
}

require_space_free_root_dir() {
  if [[ "$ROOT_DIR" =~ [[:space:]] ]]; then
    error "sandbox root '$ROOT_DIR' contains whitespace; move it to a path without spaces"
    exit 1
  fi
}

resolve_root_dir() {
  local root_input
  local resolved_root

  root_input="${OPQU_SBX_ROOT:-$PWD}"
  if ! resolved_root="$(cd "$root_input" 2>/dev/null && pwd)"; then
    error "sandbox root '$root_input' does not exist or is not accessible"
    exit 1
  fi

  ROOT_DIR="$resolved_root"
}

validate_name() {
  local name="$1"
  local length="${#name}"

  if [[ ! "$name" =~ ^[a-z0-9-]{1,12}$ ]]; then
    error "sandbox name '$name' is invalid (${length} characters); must be 1–12 characters, lowercase alphanumeric and hyphens only"
    exit 1
  fi
}

load_global_config() {
  DISTRO=trixie
  MIRROR=http://deb.debian.org/debian
  VARIANT=standard
  SANDBOX_USER=""

  if [[ -f "$ROOT_DIR/conf/global.conf" ]]; then
    # shellcheck disable=SC1091
    source "$ROOT_DIR/conf/global.conf"
  fi

  if [[ -z "${SANDBOX_USER:-}" ]]; then
    SANDBOX_USER="$(whoami)"
  fi
}

load_sandbox_config() {
  local name="$1"

  PORTS=""
  AUDIO=no

  if [[ -f "$ROOT_DIR/conf/$name.conf" ]]; then
    # shellcheck disable=SC1090
    source "$ROOT_DIR/conf/$name.conf"
  fi
}

machine_name() {
  printf 'opqu-sbx-%s' "$1"
}

zone_name() {
  local name="$1"
  local base_prefix="opqu"
  local full="${base_prefix}-${name}"

  if [[ ${#full} -le 12 ]]; then
    echo "$full"
  else
    local available=$((12 - ${#name}))
    if [[ $available -ge 2 ]]; then
      echo "${base_prefix:0:$((available - 1))}-${name}"
    elif [[ $available -eq 1 ]]; then
      echo "o${name}"
    else
      echo "${name:0:12}"
    fi
  fi
}

bridge_name() {
  printf 'vz-%s' "$(zone_name "$1")"
}

default_snapshot_path() {
  local name="$1"

  printf '%s/opqu-sbx-%s.snapshot.tar.zst' "$PWD" "$name"
}

is_running() {
  local name="$1"
  local machine
  local list_output

  machine="$(machine_name "$name")"
  if ! list_output="$(machinectl list --no-legend 2>/dev/null)"; then
    error "failed to query sandbox state with machinectl"
    exit 1
  fi

  if grep -Eq "^${machine}[[:space:]]" <<<"$list_output"; then
    return 0
  fi

  return 1
}

build_include_arg() {
  local name="$1"
  local packages_file="$ROOT_DIR/conf/$name.packages"
  local -a packages=()
  local line
  local joined=""
  local package
  declare -A seen=()

  if [[ -f "$packages_file" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" =~ ^[[:space:]]*$ ]]; then
        continue
      fi
      if [[ "$line" =~ ^[[:space:]]*# ]]; then
        continue
      fi
      packages+=("$line")
    done <"$packages_file"
  fi

  if [[ "$AUDIO" == "yes" ]]; then
    packages+=("pipewire-pulse")
  fi

  for package in "${packages[@]}"; do
    if [[ -n "${seen[$package]:-}" ]]; then
      continue
    fi
    seen["$package"]=1
    if [[ -n "$joined" ]]; then
      joined+=","
    fi
    joined+="$package"
  done

  if [[ -n "$joined" ]]; then
    printf '%s\n' "$joined"
  fi
}

build_mount_flags() {
  local name="$1"
  local mounts_file="$ROOT_DIR/conf/$name.mounts"
  local line
  local host_path
  local container_path
  local mode

  MOUNT_FLAGS=()

  if [[ ! -f "$mounts_file" ]]; then
    return
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^[[:space:]]*$ ]]; then
      continue
    fi
    if [[ "$line" =~ ^[[:space:]]*# ]]; then
      continue
    fi

    if [[ "$line" =~ ^([^:]+):([^:]+)(:ro)?$ ]]; then
      host_path="${BASH_REMATCH[1]}"
      container_path="${BASH_REMATCH[2]}"
      mode="${BASH_REMATCH[3]}"
      if [[ "$mode" == ":ro" ]]; then
        MOUNT_FLAGS+=("--bind-ro=${host_path}:${container_path}")
      else
        MOUNT_FLAGS+=("--bind=${host_path}:${container_path}")
      fi
    else
      error "invalid mount entry in conf/$name.mounts: '$line'"
      exit 1
    fi
  done <"$mounts_file"
}

build_port_flags() {
  PORT_FLAGS=()
  local port

  if [[ -z "${PORTS:-}" ]]; then
    return
  fi

  for port in $PORTS; do
    PORT_FLAGS+=("--port=$port")
  done
}

build_audio_flags() {
  AUDIO_FLAGS=()

  if [[ "$AUDIO" == "yes" ]]; then
    AUDIO_FLAGS+=("--bind=/run/user/$(id -u)/pipewire-0:/run/user/host/pipewire-0")
    AUDIO_FLAGS+=("--setenv=PIPEWIRE_REMOTE=/run/user/host/pipewire-0")
  fi
}

cmd_create() {
  local name="$1"
  local rootfs="$ROOT_DIR/rootfs-$name"
  local tarball="$ROOT_DIR/rootfs-$name.base.tar.zst"
  local include_list=""
  local -a mmdebstrap_args=()
  local -a debootstrap_args=()
  local enable_networkd_hook
  local create_user_hook
  local cache_in_hook
  local cache_out_hook
  local uid

  require_space_free_root_dir

  if [[ -d "$rootfs" ]]; then
    error "sandbox '$name' already exists"
    exit 1
  fi

  load_global_config

  if ! id "$SANDBOX_USER" >/dev/null 2>&1; then
    error "SANDBOX_USER '$SANDBOX_USER' does not exist on the host; create it first"
    exit 1
  fi

  uid="$(id -u "$SANDBOX_USER")"

  if ! sudo mkdir -p "$ROOT_DIR/pkg-cache"; then
    error "failed to create pkg-cache directory"
    exit 1
  fi

  load_sandbox_config "$name"
  include_list="$(build_include_arg "$name")"

  if command -v mmdebstrap >/dev/null 2>&1; then
    mmdebstrap_args=(
      "--variant=$VARIANT"
      "--skip=essential/unlink"
      "--setup-hook=mkdir -p \"\$1/var/cache/apt/archives/\""
    )

    printf -v cache_in_hook 'sync-in %q /var/cache/apt/archives/' "$ROOT_DIR/pkg-cache"
    printf -v cache_out_hook 'sync-out /var/cache/apt/archives %q' "$ROOT_DIR/pkg-cache"
    mmdebstrap_args+=(
      "--setup-hook=$cache_in_hook"
      "--customize-hook=$cache_out_hook"
    )

    # shellcheck disable=SC2016
    printf -v enable_networkd_hook 'chroot "$1" systemctl enable systemd-networkd'
    # shellcheck disable=SC2016
    printf -v create_user_hook \
      'chroot "$1" /bin/sh -c %q' \
      "useradd -m -u $uid -s /bin/bash $SANDBOX_USER && passwd -l root && passwd -l $SANDBOX_USER"
    mmdebstrap_args+=(
      "--customize-hook=$enable_networkd_hook"
      "--customize-hook=$create_user_hook"
    )

    if [[ -n "$include_list" ]]; then
      mmdebstrap_args+=("--include=$include_list")
    fi

    if ! sudo mmdebstrap \
      "${mmdebstrap_args[@]}" \
      "$DISTRO" \
      "$rootfs" \
      "$MIRROR"; then
      error "bootstrapping sandbox '$name' with mmdebstrap failed"
      exit 1
    fi
  elif command -v debootstrap >/dev/null 2>&1; then
    log "mmdebstrap not found, falling back to debootstrap..."

    debootstrap_args=(
      "--variant=$VARIANT"
    )

    if [[ -n "$include_list" ]]; then
      debootstrap_args+=("--include=$include_list")
    fi

    if ! sudo debootstrap \
      "${debootstrap_args[@]}" \
      "$DISTRO" \
      "$rootfs" \
      "$MIRROR"; then
      error "bootstrapping sandbox '$name' with debootstrap failed"
      exit 1
    fi

    # Enable networking
    if ! sudo chroot "$rootfs" systemctl enable systemd-networkd; then
      error "failed to enable systemd-networkd"
      exit 1
    fi

    # Create user and lock root
    local user_script="useradd -m -u $uid -s /bin/bash $SANDBOX_USER && passwd -l root && passwd -l $SANDBOX_USER"
    if ! sudo chroot "$rootfs" /bin/sh -c "$user_script"; then
      error "failed to create sandbox user"
      exit 1
    fi
  else
    error "neither mmdebstrap nor debootstrap found in PATH"
    exit 1
  fi

  if ! sudo tar --zstd -cf "$tarball" -C "$ROOT_DIR" "rootfs-$name/"; then
    error "failed to create base tarball for sandbox '$name'"
    exit 1
  fi
}

cmd_start() {
  local name="$1"
  local machine
  local rootfs="$ROOT_DIR/rootfs-$name"

  if [[ ! -d "$rootfs" ]]; then
    error "sandbox '$name' does not exist"
    exit 1
  fi

  load_global_config
  load_sandbox_config "$name"
  build_mount_flags "$name"
  build_port_flags
  build_audio_flags
  machine="$(machine_name "$name")"

  exec sudo systemd-run \
    --unit="$machine" \
    --description="opqu-sandbox $name" \
    --collect \
    systemd-nspawn \
    --boot \
    --machine="$machine" \
    --directory="$rootfs" \
    --network-zone="$(zone_name "$name")" \
    --resolv-conf=replace-uplink \
    "${MOUNT_FLAGS[@]}" \
    "${PORT_FLAGS[@]}" \
    "${AUDIO_FLAGS[@]}"
}

cmd_shell() {
  local name="$1"
  shift
  local machine

  load_global_config
  machine="$(machine_name "$name")"

  exec sudo machinectl shell "$SANDBOX_USER@$machine" "$@"
}

cmd_stop() {
  local name="$1"
  local machine

  if ! is_running "$name"; then
    exit 0
  fi

  machine="$(machine_name "$name")"
  exec sudo machinectl poweroff "$machine"
}

cmd_reset() {
  local name="$1"
  local bridge
  local machine

  if is_running "$name"; then
    error "sandbox '$name' is running; stop it first"
    exit 1
  fi

  if ! sudo rm -rf "$ROOT_DIR/rootfs-$name"; then
    error "failed to remove rootfs for sandbox '$name'"
    exit 1
  fi

  if ! sudo tar --zstd -xf "$ROOT_DIR/rootfs-$name.base.tar.zst" -C "$ROOT_DIR"; then
    exit 1
  fi

  bridge="$(bridge_name "$name")"
  machine="$(machine_name "$name")"
  sudo ip link delete "$bridge" 2>/dev/null || true
  sudo systemctl reset-failed "$machine" 2>/dev/null || true
}

cmd_snapshot() {
  local name="$1"
  local output_path="${2:-}"
  local output_dir
  local output_base
  local tmp_output

  if is_running "$name"; then
    error "sandbox '$name' is running; stop it first"
    exit 1
  fi

  if [[ -z "$output_path" ]]; then
    output_path="$(default_snapshot_path "$name")"
  fi

  if [[ -e "$output_path" ]]; then
    error "snapshot output '$output_path' already exists; move it away first"
    exit 1
  fi

  output_dir="$(dirname "$output_path")"
  output_base="$(basename "$output_path")"
  if ! tmp_output="$(mktemp "$output_dir/.${output_base}.tmp.XXXXXX")"; then
    error "failed to create temporary snapshot file in '$output_dir'"
    exit 1
  fi

  # shellcheck disable=SC2024
  if ! sudo tar -I 'zstd -19 -T0' -cf - -C "$ROOT_DIR" "rootfs-$name/" >"$tmp_output"; then
    rm -f "$tmp_output"
    exit 1
  fi

  if ! mv "$tmp_output" "$output_path"; then
    error "failed to move snapshot into place at '$output_path'; temporary snapshot kept at '$tmp_output'"
    exit 1
  fi
}

cmd_restore() {
  local name="$1"
  local snapshot_path="$2"
  local expected_rootfs="rootfs-$name/"
  local entry
  local tar_listing
  local found_rootfs=0

  if is_running "$name"; then
    error "sandbox '$name' is running; stop it first"
    exit 1
  fi

  if [[ ! -e "$snapshot_path" ]]; then
    error "snapshot '$snapshot_path' does not exist"
    exit 1
  fi

  if [[ ! -f "$snapshot_path" ]]; then
    error "snapshot '$snapshot_path' is not a regular file"
    exit 1
  fi

  if [[ ! -r "$snapshot_path" ]]; then
    error "snapshot '$snapshot_path' is not readable"
    exit 1
  fi

  if ! tar_listing="$(sudo tar --zstd -tf "$snapshot_path")"; then
    exit 1
  fi

  while IFS= read -r entry; do
    if [[ "$entry" == "$expected_rootfs" ]]; then
      found_rootfs=1
    fi
  done <<<"$tar_listing"

  if [[ "$found_rootfs" -ne 1 ]]; then
    error "snapshot '$snapshot_path' does not contain top-level '$expected_rootfs'"
    exit 1
  fi

  if ! sudo rm -rf "$ROOT_DIR/rootfs-$name"; then
    error "failed to remove rootfs for sandbox '$name'"
    exit 1
  fi

  if ! sudo tar --zstd -xf "$snapshot_path" -C "$ROOT_DIR"; then
    exit 1
  fi
}

cmd_delete() {
  local name="$1"
  local bridge
  local machine

  if is_running "$name"; then
    error "sandbox '$name' is running; stop it first"
    exit 1
  fi

  if ! sudo rm -rf "$ROOT_DIR/rootfs-$name"; then
    error "failed to remove rootfs for sandbox '$name'"
    exit 1
  fi

  if ! sudo rm -f "$ROOT_DIR/rootfs-$name.base.tar.zst"; then
    error "failed to remove base tarball for sandbox '$name'"
    exit 1
  fi

  # Keep config files but inform the user
  local -a config_files=(
    "$ROOT_DIR/conf/$name.conf"
    "$ROOT_DIR/conf/$name.packages"
    "$ROOT_DIR/conf/$name.mounts"
  )
  local found_configs=()
  for f in "${config_files[@]}"; do
    if [[ -f "$f" ]]; then
      found_configs+=("$(basename "$f")")
    fi
  done

  if [[ ${#found_configs[@]} -gt 0 ]]; then
    printf "Keeping configuration files in conf/:\n"
    for f in "${found_configs[@]}"; do
      printf "  %s\n" "$f"
    done
  fi

  bridge="$(bridge_name "$name")"
  machine="$(machine_name "$name")"
  sudo ip link delete "$bridge" 2>/dev/null || true
  sudo systemctl reset-failed "$machine" 2>/dev/null || true
}

cmd_status() {
  local name="$1"

  if [[ -z "$name" ]]; then
    printf "%s\n" "--- Host Commands ---"
    local commands=(systemctl systemd-nspawn systemd-run machinectl tar zstd ip)
    for c in "${commands[@]}"; do
      status="OK"
      if ! command -v "$c" >/dev/null 2>&1; then
        status="MISSING"
      fi
      printf "%-18s %s\n" "$c:" "$status"
    done

    mm_status="MISSING"
    if command -v mmdebstrap >/dev/null 2>&1; then
      mm_status="OK"
    fi
    printf "%-18s %s (Primary)\n" "mmdebstrap:" "$mm_status"

    deb_status="MISSING"
    if command -v debootstrap >/dev/null 2>&1; then
      deb_status="OK"
    fi
    printf "%-18s %s (Fallback)\n" "debootstrap:" "$deb_status"

    printf "\n%s\n" "--- Networking ---"
    networkd_status="INACTIVE"
    if systemctl is-active --quiet systemd-networkd; then
      networkd_status="ACTIVE"
    fi
    printf "%-18s %s\n" "systemd-networkd:" "$networkd_status"

    ip_forward_status="DISABLED"
    if [[ -f /proc/sys/net/ipv4/ip_forward ]]; then
      if [[ $(< /proc/sys/net/ipv4/ip_forward) == "1" ]]; then
        ip_forward_status="ENABLED"
      fi
    fi
    printf "%-18s %s\n" "IP Forwarding:" "$ip_forward_status"

    printf "\n%s\n" "--- Container User ---"
    load_global_config
    if id "$SANDBOX_USER" >/dev/null 2>&1; then
      printf "SANDBOX_USER '%s': OK (UID: %s)\n" "$SANDBOX_USER" "$(id -u "$SANDBOX_USER")"
    else
      printf "SANDBOX_USER '%s': MISSING (does not exist on host)\n" "$SANDBOX_USER"
    fi

    printf "\n%s\n" "--- Existing Rootfs ---"
    local rootfs_found=0
    # Use globbing to list directories starting with rootfs- in the root directory
    for dir in "$ROOT_DIR"/rootfs-*; do
      if [[ -d "$dir" ]]; then
        basename "$dir"
        rootfs_found=1
      fi
    done

    if [[ $rootfs_found -eq 0 ]]; then
      printf "(none)\n"
    fi

    printf "\n%s\n" "--- Running Sandboxes ---"
    local machine_list
    local header
    local matched_lines
    local count

    if ! machine_list="$(machinectl list 2>/dev/null)"; then
      error "failed to query sandbox status with machinectl"
      exit 1
    fi

    header="$(printf '%s\n' "$machine_list" | sed -n '1p')"
    matched_lines="$(printf '%s\n' "$machine_list" | awk 'NR > 1 && /^opqu-sbx-/')"

    printf '%s\n' "$header"
    if [[ -n "$matched_lines" ]]; then
      printf '%s\n' "$matched_lines"
      count="$(printf '%s\n' "$matched_lines" | wc -l | tr -d ' ')"
    else
      count=0
    fi
    printf '%s machines listed.\n' "$count"
  else
    printf "Sandbox: %s\n" "$name"

    if [[ -d "$ROOT_DIR/rootfs-$name" ]]; then
      printf "Existence:   EXISTS\n"
    else
      printf "Existence:   MISSING\n"
    fi

    if [[ -f "$ROOT_DIR/rootfs-$name.base.tar.zst" ]]; then
      printf "Base Image:  EXISTS\n"
    else
      printf "Base Image:  MISSING\n"
    fi

    if is_running "$name"; then
      printf "Running:     YES\n"
    else
      printf "Running:     NO\n"
    fi

    load_sandbox_config "$name"
    if [[ -n "${PORTS:-}" ]]; then
      printf "Ports:       %s\n" "$PORTS"
    else
      printf "Ports:       (none)\n"
    fi

    printf "Configuration:\n"
    local configs=("$name.conf" "$name.packages" "$name.mounts")
    for c in "${configs[@]}"; do
      status="MISSING"
      if [[ -f "$ROOT_DIR/conf/$c" ]]; then
        status="EXISTS"
      fi
      printf "  %-12s %s\n" "$c:" "$status"
    done
  fi
}

main() {
  local cmd
  local name
  local root_arg=""
  local path_arg=""

  if [[ "${1:-}" == "--root" ]]; then
    if [[ $# -lt 2 ]]; then
      usage
      exit 1
    fi
    root_arg="$2"
    shift 2
  fi

  cmd="${1:-}"

  case "$cmd" in
    help|-h|--help)
      usage
      exit 0
      ;;
  esac

  name="${2:-}"

  case "$cmd" in
    create|start|stop|reset|delete)
      if [[ $# -ne 2 ]]; then
        usage
        exit 1
      fi
      validate_name "$name"
      ;;
    shell)
      if [[ $# -lt 2 ]]; then
        usage
        exit 1
      fi
      validate_name "$name"
      ;;
    snapshot)
      if [[ $# -ne 2 && $# -ne 3 ]]; then
        usage
        exit 1
      fi
      validate_name "$name"
      path_arg="${3:-}"
      ;;
    restore)
      if [[ $# -ne 3 ]]; then
        usage
        exit 1
      fi
      validate_name "$name"
      path_arg="$3"
      ;;
    status)
      if [[ $# -ne 1 && $# -ne 2 ]]; then
        usage
        exit 1
      fi
      if [[ $# -eq 2 ]]; then
        validate_name "$name"
      fi
      ;;
    *)
      usage
      exit 1
      ;;
  esac

  if [[ -n "$root_arg" ]]; then
    OPQU_SBX_ROOT="$root_arg"
  fi

  resolve_root_dir

  case "$cmd" in
    create) cmd_create "$name" ;;
    start) cmd_start "$name" ;;
    shell) shift 2; cmd_shell "$name" "$@" ;;
    stop) cmd_stop "$name" ;;
    reset) cmd_reset "$name" ;;
    snapshot) cmd_snapshot "$name" "$path_arg" ;;
    restore) cmd_restore "$name" "$path_arg" ;;
    delete) cmd_delete "$name" ;;
    status) cmd_status "$name" ;;
  esac
}

main "$@"
